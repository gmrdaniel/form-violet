# Supabase — server-only inserts from /app/api/submit/route.ts.
# No NEXT_PUBLIC_ prefix on purpose: these values stay on the Node server,
# never in the client bundle. The API route uses the service_role key and
# bypasses RLS, so no anon key is needed here.
#
# Both values come from the shared Supabase project's Dashboard:
# Settings -> API -> Project URL + service_role key.
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.REPLACE_ME
